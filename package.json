{
  "name": "plainpolitics",
  "version": "1.0.0",
  "description": "PlainPolitics — Civic Survival Assistant (MERN + Gemini + Cloud Run)",
  "private": true,
  "scripts": {
    "dev":          "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"cyan,magenta\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server":   "npm --prefix server run dev",
    "dev:client":   "npm --prefix client run dev",
    "build":        "npm --prefix client run build",
    "install:all":  "npm install && npm --prefix server install && npm --prefix client install",
    "start":        "npm --prefix server run start"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
