# Server environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Local development ──────────────────────────────────────────────────────────
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/plainpolitics?retryWrites=true&w=majority

# Gemini REST API key (local dev only — NOT needed on Cloud Run)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Cloud Run (production) ─────────────────────────────────────────────────────
# These are set automatically by cloudbuild.yaml — do NOT set manually.
# Vertex AI uses the Cloud Run service account (Application Default Credentials).
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# NODE_ENV=production
# MONGO_URI is injected from Secret Manager via --set-secrets in cloudbuild.yaml
